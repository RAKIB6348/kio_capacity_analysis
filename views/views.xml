<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kio_capacity_dashboard_kanban" model="ir.ui.view">
        <field name="name">kio.capacity.dashboard.kanban</field>
        <field name="model">kio.capacity.dashboard</field>
        <field name="arch" type="xml">
            <kanban class="o_kio_capacity_dashboard" create="false" edit="false" delete="false">
                <field name="total_capacity"/>
                <field name="bandwidth_capacity"/>
                <field name="mac_capacity"/>
                <field name="free_capacity"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="o_kio_dashboard_wrapper">

                            <!-- Dashboard Header -->
                            <div class="o_kio_dashboard_header">
                                <div>
                                    <div class="o_kio_breadcrumb">
                                        <span>Capacity Analysis</span>
                                        <i class="fa fa-chevron-right"/>
                                        <span class="o_kio_breadcrumb_current">Capacity Dashboard</span>
                                    </div>

                                    <h1 class="o_kio_dashboard_title">Capacity Dashboard</h1>
                                    <p class="o_kio_dashboard_subtitle">
                                        Overview of system capacity and resource availability
                                    </p>
                                </div>

                                <div class="o_kio_today_btn">
                                    <i class="fa fa-calendar-o"/>
                                    <span>Today</span>
                                    <i class="fa fa-angle-down"/>
                                </div>
                            </div>

                            <!-- Metric Cards -->
                            <div class="o_kio_dashboard_grid">

                                <!-- Total Capacity -->
                                <div class="o_kio_metric_card o_kio_metric_total">
                                    <div class="o_kio_top_line"></div>

                                    <div class="o_kio_icon_row">
                                        <div class="o_kio_metric_icon">
                                            <i class="fa fa-database"/>
                                        </div>
                                        <div class="o_kio_dot_pattern"></div>
                                    </div>

                                    <div class="o_kio_metric_label">Total Capacity</div>

                                    <div class="o_kio_metric_value">
                                        <field name="total_capacity"/>
                                        <span class="o_kio_metric_unit">GB</span>
                                    </div>
                                </div>

                                <!-- Bandwidth Capacity -->
                                <div class="o_kio_metric_card o_kio_metric_bandwidth">
                                    <div class="o_kio_top_line"></div>

                                    <div class="o_kio_icon_row">
                                        <div class="o_kio_metric_icon">
                                            <i class="fa fa-signal"/>
                                        </div>
                                        <div class="o_kio_dot_pattern"></div>
                                    </div>

                                    <div class="o_kio_metric_label">Bandwidth Capacity</div>

                                    <div class="o_kio_metric_value">
                                        <field name="bandwidth_capacity"/>
                                        <span class="o_kio_metric_unit">Mbps</span>
                                    </div>
                                </div>

                                <!-- MAC Capacity -->
                                <div class="o_kio_metric_card o_kio_metric_mac">
                                    <div class="o_kio_top_line"></div>

                                    <div class="o_kio_icon_row">
                                        <div class="o_kio_metric_icon">
                                            <i class="fa fa-server"/>
                                        </div>
                                        <div class="o_kio_dot_pattern"></div>
                                    </div>

                                    <div class="o_kio_metric_label">MAC Capacity</div>

                                    <div class="o_kio_metric_value">
                                        <field name="mac_capacity"/>
                                        <span class="o_kio_metric_unit">Units</span>
                                    </div>
                                </div>

                                <!-- Free Capacity -->
                                <div class="o_kio_metric_card o_kio_metric_free">
                                    <div class="o_kio_top_line"></div>

                                    <div class="o_kio_icon_row">
                                        <div class="o_kio_metric_icon">
                                            <i class="fa fa-shield"/>
                                        </div>
                                        <div class="o_kio_dot_pattern"></div>
                                    </div>

                                    <div class="o_kio_metric_label">Free Capacity</div>

                                    <div class="o_kio_metric_value">
                                        <field name="free_capacity"/>
                                        <span class="o_kio_metric_unit">GB</span>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action -->
    <record id="action_kio_capacity_dashboard" model="ir.actions.act_window">
        <field name="name">Capacity Dashboard</field>
        <field name="res_model">kio.capacity.dashboard</field>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_kio_capacity_dashboard_kanban"/>
        <field name="target">current</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_kio_capacity_root"
              name="Capacity Analysis"
              sequence="10"/>

    <menuitem id="menu_kio_capacity_dashboard"
              name="Dashboard"
              parent="menu_kio_capacity_root"
              action="action_kio_capacity_dashboard"
              sequence="10"/>

</odoo>